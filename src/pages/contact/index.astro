---
import Layout from "../../layouts/Layout.astro";
import { getLang, useTranslations } from "../../i18n/utils";

const lang = getLang(Astro.url, import.meta.env.BASE_URL);
const t = useTranslations(lang);
---

<Layout
    t={t}
    lang={lang}
    title={t.contact.pageTitle}
    description={t.contact.pageDesc}
>
    <main>
        <!-- Hero banner -->
        <div class="contact-hero">
            <div class="container">
                <span class="contact-hero__badge">{t.contact.badge}</span>
                <h1 class="contact-hero__title">{t.contact.title}</h1>
                <p class="contact-hero__desc">{t.contact.description}</p>
            </div>
        </div>

        <!-- Main content -->
        <div class="contact-body">
            <div class="container contact-body__grid">
                <!-- Left column: info + social + map -->
                <div class="contact-left reveal">
                    <!-- Contact info -->
                    <div class="contact-info">
                        <h2 class="contact-info__title">
                            {t.contact.info.title}
                        </h2>

                        <a
                            href={`mailto:${t.contact.info.email}`}
                            class="contact-info__item"
                        >
                            <div
                                class="contact-info__icon contact-info__icon--blue"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><rect
                                        width="20"
                                        height="16"
                                        x="2"
                                        y="4"
                                        rx="2"></rect><path
                                        d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <p class="contact-info__item-label">EMAIL</p>
                                <p class="contact-info__item-value">
                                    {t.contact.info.email}
                                </p>
                            </div>
                        </a>

                        <a
                            href={`https://wa.me/5255999035460`}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="contact-info__item"
                        >
                            <div
                                class="contact-info__icon contact-info__icon--green"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <p class="contact-info__item-label">PHONE</p>
                                <p class="contact-info__item-value">
                                    {t.contact.info.phone}
                                </p>
                            </div>
                        </a>

                        <div
                            class="contact-info__item contact-info__item--no-link"
                        >
                            <div
                                class="contact-info__icon contact-info__icon--orange"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
                                    ></path><circle cx="12" cy="10" r="3"
                                    ></circle></svg
                                >
                            </div>
                            <div>
                                <p class="contact-info__item-label">ADDRESS</p>
                                <p class="contact-info__item-value">
                                    {t.contact.info.address}
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Social links -->
                    <div class="contact-social">
                        <h3 class="contact-social__title">
                            {t.contact.social.title}
                        </h3>
                        <div class="contact-social__grid">
                            <a
                                href="https://facebook.com"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="contact-social__btn contact-social__btn--facebook"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    ><path
                                        d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                                    ></path></svg
                                >
                                Facebook
                            </a>
                            <a
                                href="https://instagram.com"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="contact-social__btn contact-social__btn--instagram"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><rect
                                        width="20"
                                        height="20"
                                        x="2"
                                        y="2"
                                        rx="5"
                                        ry="5"></rect><path
                                        d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
                                    ></path><line
                                        x1="17.5"
                                        x2="17.51"
                                        y1="6.5"
                                        y2="6.5"></line></svg
                                >
                                Instagram
                            </a>
                            <a
                                href="https://linkedin.com"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="contact-social__btn contact-social__btn--linkedin"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    ><path
                                        d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                                    ></path><rect
                                        width="4"
                                        height="12"
                                        x="2"
                                        y="9"></rect><circle cx="4" cy="4" r="2"
                                    ></circle></svg
                                >
                                LinkedIn
                            </a>
                            <a
                                href="https://wa.me/5255999035460"
                                target="_blank"
                                rel="noopener noreferrer"
                                class="contact-social__btn contact-social__btn--whatsapp"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="currentColor"
                                    ><path
                                        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"
                                    ></path></svg
                                >
                                WhatsApp
                            </a>
                        </div>
                    </div>

                    <!-- Map -->
                    <div class="contact-map">
                        <h3 class="contact-map__title">
                            {t.contact.map.title}
                        </h3>
                        <div id="contact-map" class="contact-map__container">
                        </div>
                    </div>
                </div>

                <!-- Right column: form -->
                <div class="contact-right reveal" data-delay="150">
                    <div class="contact-form-wrap">
                        <h2 class="contact-form__title">
                            {t.contact.form.title}
                        </h2>

                        <form
                            id="contact-form"
                            class="contact-form"
                            action="https://forms.zohopublic.com/promaica/form/SolicituddeCotizacin/formperma/0G7mUvm1mHqTMr77oTQpng90acA6JYYKZtboiNDls70/htmlRecords/submit"
                            method="POST"
                            accept-charset="UTF-8"
                            enctype="multipart/form-data"
                        >
                            <!-- Campos ocultos requeridos por Zoho -->
                            <input
                                type="hidden"
                                name="zf_referrer_name"
                                value=""
                            />
                            <input
                                type="hidden"
                                name="zf_redirect_url"
                                value=""
                            />
                            <input type="hidden" name="zc_gad" value="" />

                            <div class="contact-form__row">
                                <div class="contact-form__field">
                                    <label
                                        for="cf-name"
                                        class="contact-form__label"
                                        >{t.contact.form.labelName}</label
                                    >
                                    <input
                                        type="text"
                                        id="cf-name"
                                        name="Name_First"
                                        maxlength="255"
                                        required
                                        placeholder={t.contact.form
                                            .placeholderName}
                                        class="contact-form__input"
                                    />
                                </div>
                                <div class="contact-form__field">
                                    <label
                                        for="cf-email"
                                        class="contact-form__label"
                                        >{t.contact.form.labelEmail}</label
                                    >
                                    <input
                                        type="email"
                                        id="cf-email"
                                        name="Email"
                                        maxlength="255"
                                        required
                                        placeholder={t.contact.form
                                            .placeholderEmail}
                                        class="contact-form__input"
                                    />
                                </div>
                            </div>

                            <div class="contact-form__row">
                                <div class="contact-form__field">
                                    <label
                                        for="cf-phone"
                                        class="contact-form__label"
                                        >{t.contact.form.labelPhone}</label
                                    >
                                    <input
                                        type="tel"
                                        id="cf-phone"
                                        name="PhoneNumber_countrycode"
                                        maxlength="20"
                                        placeholder={t.contact.form
                                            .placeholderPhone}
                                        class="contact-form__input"
                                    />
                                </div>
                                <div class="contact-form__field">
                                    <label
                                        for="cf-project"
                                        class="contact-form__label"
                                        >{t.contact.form.labelProject}</label
                                    >
                                    <select
                                        id="cf-project"
                                        name="Name_Last"
                                        class="contact-form__input contact-form__select"
                                    >
                                        <option value=""
                                            >{
                                                t.contact.form.projects.select
                                            }</option
                                        >
                                        <option value="cold"
                                            >{
                                                t.contact.form.projects.cold
                                            }</option
                                        >
                                        <option value="industrial"
                                            >{
                                                t.contact.form.projects
                                                    .industrial
                                            }</option
                                        >
                                        <option value="residential"
                                            >{
                                                t.contact.form.projects
                                                    .residential
                                            }</option
                                        >
                                        <option value="commercial"
                                            >{
                                                t.contact.form.projects
                                                    .commercial
                                            }</option
                                        >
                                        <option value="other"
                                            >{
                                                t.contact.form.projects.other
                                            }</option
                                        >
                                    </select>
                                </div>
                            </div>

                            <div class="contact-form__field">
                                <label
                                    for="cf-message"
                                    class="contact-form__label"
                                    >{t.contact.form.labelMessage}</label
                                >
                                <textarea
                                    id="cf-message"
                                    name="MultiLine"
                                    maxlength="65535"
                                    rows="5"
                                    placeholder={t.contact.form
                                        .placeholderMessage}
                                    class="contact-form__input contact-form__textarea"
                                ></textarea>
                            </div>

                            <button type="submit" class="contact-form__submit">
                                {t.contact.form.submit}
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path d="m22 2-7 20-4-9-9-4Z"></path><path
                                        d="M22 2 11 13"></path></svg
                                >
                            </button>
                        </form>

                        <!-- Success -->
                        <div
                            id="contact-success"
                            class="contact-form__success"
                            aria-hidden="true"
                        >
                            <div class="contact-form__success-icon">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="28"
                                    height="28"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path d="M20 6 9 17l-5-5"></path></svg
                                >
                            </div>
                            <h4>{t.contact.form.successTitle}</h4>
                            <p>{t.contact.form.successMsg}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>

<link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
/>

<style>
    /* ── Hero banner ── */
    .contact-hero {
        background: linear-gradient(
            160deg,
            var(--color-slate-900),
            var(--color-slate-950)
        );
        color: white;
        padding-block: 5rem 4rem;
        position: relative;
        overflow: hidden;
    }

    .contact-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
            linear-gradient(rgb(255 255 255 / 0.025) 1px, transparent 1px),
            linear-gradient(
                90deg,
                rgb(255 255 255 / 0.025) 1px,
                transparent 1px
            );
        background-size: 48px 48px;
    }

    .contact-hero .container {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
        max-width: 48rem;
    }

    .contact-hero__badge {
        display: inline-block;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--color-brand-400);
    }

    .contact-hero__title {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
    }

    .contact-hero__desc {
        font-size: 1rem;
        color: var(--color-slate-300);
        line-height: 1.7;
        max-width: 36rem;
    }

    /* ── Body ── */
    .contact-body {
        padding-block: var(--space-16);
        background: var(--color-slate-50);
    }

    .contact-body__grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-8);
        align-items: start;
    }

    @media (min-width: 1024px) {
        .contact-body__grid {
            grid-template-columns: 1fr 1.4fr;
            gap: var(--space-12);
        }
    }

    /* ── Left column ── */
    .contact-left {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    /* ── Contact info ── */
    .contact-info {
        background: white;
        border: 1px solid var(--color-slate-100);
        border-radius: var(--radius-2xl);
        padding: var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
        box-shadow: var(--shadow-sm);
    }

    .contact-info__title {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-slate-400);
        padding-bottom: var(--space-2);
        border-bottom: 1px solid var(--color-slate-100);
    }

    .contact-info__item {
        display: flex;
        align-items: flex-start;
        gap: var(--space-4);
        padding: var(--space-3);
        border-radius: var(--radius-md);
        transition: background 0.2s;
        text-decoration: none;
        color: inherit;
    }

    .contact-info__item:not(.contact-info__item--no-link):hover {
        background: var(--color-slate-50);
    }

    .contact-info__icon {
        width: 2.5rem;
        height: 2.5rem;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .contact-info__icon--blue {
        background: var(--color-blue-100);
        color: var(--color-blue-600);
    }

    .contact-info__icon--green {
        background: var(--color-emerald-100);
        color: var(--color-emerald-600);
    }

    .contact-info__icon--orange {
        background: var(--color-thermal-50);
        color: var(--color-thermal-600);
    }

    .contact-info__item-label {
        font-size: 0.62rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        color: var(--color-slate-400);
        margin-bottom: 2px;
    }

    .contact-info__item-value {
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-slate-700);
        line-height: 1.5;
    }

    /* ── Social ── */
    .contact-social {
        background: white;
        border: 1px solid var(--color-slate-100);
        border-radius: var(--radius-2xl);
        padding: var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
        box-shadow: var(--shadow-sm);
    }

    .contact-social__title {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-slate-400);
        padding-bottom: var(--space-2);
        border-bottom: 1px solid var(--color-slate-100);
    }

    .contact-social__grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-3);
    }

    .contact-social__btn {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-4);
        border-radius: var(--radius-md);
        font-size: 0.8rem;
        font-weight: 600;
        transition:
            opacity 0.2s,
            transform 0.2s;
        text-decoration: none;
    }

    .contact-social__btn:hover {
        opacity: 0.85;
        transform: translateY(-1px);
    }

    .contact-social__btn--facebook {
        background: #1877f2;
        color: white;
    }

    .contact-social__btn--instagram {
        background: linear-gradient(
            135deg,
            #f09433,
            #e6683c,
            #dc2743,
            #cc2366,
            #bc1888
        );
        color: white;
    }

    .contact-social__btn--linkedin {
        background: #0a66c2;
        color: white;
    }

    .contact-social__btn--whatsapp {
        background: #25d366;
        color: white;
    }

    /* ── Map ── */
    .contact-map {
        background: white;
        border: 1px solid var(--color-slate-100);
        border-radius: var(--radius-2xl);
        padding: var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }

    .contact-map__title {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-slate-400);
        padding-bottom: var(--space-2);
        border-bottom: 1px solid var(--color-slate-100);
    }

    .contact-map__container {
        height: 220px;
        border-radius: var(--radius-lg);
        overflow: hidden;
        z-index: 0;
    }

    /* ── Right column: form ── */
    .contact-right {
        position: sticky;
        top: 6rem;
    }

    .contact-form-wrap {
        background: white;
        border: 1px solid var(--color-slate-100);
        border-radius: var(--radius-2xl);
        padding: var(--space-8);
        box-shadow: var(--shadow-lg);
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .contact-form__title {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--color-slate-900);
        letter-spacing: -0.02em;
    }

    /* ── Form fields ── */
    .contact-form {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .contact-form.is-hidden {
        display: none;
    }

    .contact-form__row {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-4);
    }

    @media (min-width: 640px) {
        .contact-form__row {
            grid-template-columns: 1fr 1fr;
        }
    }

    .contact-form__field {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .contact-form__label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-slate-500);
    }

    .contact-form__input {
        width: 100%;
        padding: var(--space-3) var(--space-4);
        border: 1px solid var(--color-slate-200);
        border-radius: var(--radius-md);
        font-size: 0.875rem;
        font-family: inherit;
        color: var(--color-slate-800);
        background: var(--color-slate-50);
        transition:
            border-color 0.2s,
            box-shadow 0.2s,
            background 0.2s;
        outline: none;
    }

    .contact-form__input:focus {
        border-color: var(--color-brand-500);
