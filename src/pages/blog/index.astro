---
import { BlogList } from "astro-blog-kit/components";
import { createWPClient } from "astro-blog-kit/utils";
import config from "../../../blog.config";
import Layout from "../../layouts/Layout.astro";
import { getLang, useTranslations } from "../../i18n/utils";

const wp = createWPClient(config.wpUrl);
const { posts, totalPages } = await wp.getPosts({ perPage: config.postsPerPage ?? 5 });

const bt = {
  blog: {
    tagline: "Our Blog",
    title_line1: "Latest",
    title_line2: "Articles",
    description: "Welcome to our blog.",
    btncta: "Read more",
    btn_prev: "Previous",
    btn_next: "Next",
  },
};

const base = import.meta.env.BASE_URL;
const lang = getLang(Astro.url, base);
const t = useTranslations(lang);


const basePath = `${base}blog/page/`;
const blogBase = `${base}blog/`;
---

<Layout t={t} lang={lang}>
  <BlogList
    posts={posts}
    currentPage={1}
    totalPages={totalPages}
    basePath={basePath}
    blogBase={blogBase}
    dateLocale={config.locale ?? "en"}
    t={bt}
    locale={config.locale ?? "en"}
    layout={config.defaultLayout ?? "magazine"}
  />
</Layout>