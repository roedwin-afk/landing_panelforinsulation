---
import Layout from "../../layouts/Layout.astro";
import CalculatorPage from "../../components/sections/CalculatorPage.astro";
import { getLang, useTranslations } from "../../i18n/utils";

const lang = getLang(Astro.url, import.meta.env.BASE_URL);
const t = useTranslations(lang);
---

<Layout
  t={t}
  lang={lang}
  title={t.calculatorPage.pageTitle}
  description={t.calculatorPage.pageDesc}
>
  <main>
    <CalculatorPage t={t} lang={lang} />
  </main>
</Layout>
