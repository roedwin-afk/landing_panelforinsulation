---
import { BlogList } from "astro-blog-kit/components";
import { createWPClient, getStaticPathsForPages } from "astro-blog-kit/utils";
import config from "../../../../../blog.config";
import Layout from "../../../../layouts/Layout.astro";
import { getLang, useTranslations } from "../../../../i18n/utils";

export async function getStaticPaths() {
  const wp = createWPClient(config.wpUrl);
  const posts = await wp.getAllPosts();
  return getStaticPathsForPages(posts, { postsPerPage: config.postsPerPage ?? 5 });
}

const { posts, currentPage, totalPages } = Astro.props;

const bt = {
  blog: {
    tagline: "Nuestro Blog",
    title_line1: "Últimos",
    title_line2: "Artículos",
    description: "Bienvenido a nuestro blog.",
    btncta: "Leer más",
    btn_prev: "Anterior",
    btn_next: "Siguiente",
  },
};

const base = import.meta.env.BASE_URL;

const lang = getLang(Astro.url, base);
const t = useTranslations(lang);

const basePath = `${base}blog/page/`;
const blogBase = `${base}blog/`;
---

<Layout t={t} lang={lang}>
  <BlogList
    posts={posts}
    currentPage={currentPage}
    totalPages={totalPages}
    basePath={basePath}
    blogBase={blogBase}
    dateLocale={config.locale ?? "en"}
    t={bt}
    locale={config.locale ?? "en"}
    layout={config.defaultLayout ?? "magazine"}
  />
</Layout>