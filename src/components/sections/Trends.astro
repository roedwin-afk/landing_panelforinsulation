---
import { Recycle, Sun } from "lucide-astro";
import type { TranslationKeys } from "../../i18n/en";

interface Props {
  t: TranslationKeys;
}

const { t } = Astro.props;

const items = [
  {
    icon: "recycle",
    title: t.trends.items[0].title,
    desc: t.trends.items[0].desc,
  },
  {
    icon: "sun",
    title: t.trends.items[1].title,
    desc: t.trends.items[1].desc,
  },
];
---

<section id="trends" class="trends">
  <div class="container">

    <!-- Header row -->
    <div class="trends__header reveal">
      <div class="trends__header-left">
        <span class="trends__badge">{t.trends.badge}</span>
        <h2 class="trends__title">{t.trends.title}</h2>
        <p class="trends__desc">{t.trends.description}</p>
      </div>
      <div class="trends__header-right">
        <span class="trends__updated">
          <span class="trends__updated-dot"></span>
          {t.trends.updated}
        </span>
      </div>
    </div>

    <!-- Items grid -->
    <div class="trends__grid">
      <div class="trends__item reveal" data-delay="0">
        <div class="trends__item-icon trends__item-icon--green">
          <Recycle size={28} />
        </div>
        <div class="trends__item-body">
          <span class="trends__item-number">01</span>
          <h3 class="trends__item-title">{items[0].title}</h3>
          <p class="trends__item-desc">{items[0].desc}</p>
        </div>
      </div>

      <div class="trends__item reveal" data-delay="120">
        <div class="trends__item-icon trends__item-icon--orange">
          <Sun size={28} />
        </div>
        <div class="trends__item-body">
          <span class="trends__item-number">02</span>
          <h3 class="trends__item-title">{items[1].title}</h3>
          <p class="trends__item-desc">{items[1].desc}</p>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .trends {
    padding-block: var(--space-20);
    background: var(--color-slate-50);
  }

  /* ── Header row ── */
  .trends__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-bottom: var(--space-16);
  }

  @media (min-width: 768px) {
    .trends__header {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .trends__header-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 38rem;
  }

  .trends__badge {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand-600);
  }

  .trends__title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--color-slate-900);
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .trends__desc {
    font-size: 1rem;
    color: var(--color-slate-600);
    line-height: 1.7;
  }

  .trends__updated {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    background: white;
    border: 1px solid var(--color-slate-200);
    border-radius: var(--radius-full);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-slate-700);
    box-shadow: var(--shadow-sm);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .trends__updated-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: #ef4444;
    flex-shrink: 0;
  }

  /* ── Grid ── */
  .trends__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .trends__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* ── Item ── */
  .trends__item {
    background: white;
    border: 1px solid var(--color-slate-100);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  @media (min-width: 640px) {
    .trends__item {
      flex-direction: row;
      align-items: flex-start;
    }
  }

  .trends__item:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  /* ── Icon ── */
  .trends__item-icon {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .trends__item-icon--green {
    background: var(--color-brand-50);
    color: var(--color-brand-600);
  }

  .trends__item-icon--orange {
    background: var(--color-thermal-50);
    color: var(--color-thermal-600);
  }

  /* ── Body ── */
  .trends__item-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .trends__item-number {
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: var(--color-slate-300);
    text-transform: uppercase;
  }

  .trends__item-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-slate-900);
    line-height: 1.3;
  }

  .trends__item-desc {
    font-size: 0.875rem;
    color: var(--color-slate-600);
    line-height: 1.75;
  }
</style>