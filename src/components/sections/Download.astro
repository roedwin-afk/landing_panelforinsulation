---
import { ArrowRight, BookOpen } from "lucide-astro";
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;

const base = import.meta.env.BASE_URL;
---

<section id="download-guide" class="cta-contact">
  <div class="cta-contact__bg">
    <div class="cta-contact__orb cta-contact__orb--green"></div>
    <div class="cta-contact__orb cta-contact__orb--orange"></div>
    <div class="cta-contact__grid"></div>
  </div>

  <div class="container cta-contact__inner reveal">
    <div class="cta-contact__copy">
      <div class="cta-contact__badge">
        <BookOpen size={14} />
        {t.download.badge}
      </div>
      <h2 class="cta-contact__title">{t.download.title}</h2>
      <p class="cta-contact__desc">{t.download.description}</p>
    </div>

    <div class="cta-contact__action">
      <a href={`${base}contact/`} class="cta-contact__btn">
        {t.nav.contact}
        <ArrowRight size={20} />
      </a>
      <p class="cta-contact__note">
        {lang === "en"
          ? "Our team responds within 24 hours."
          : "Nuestro equipo responde en menos de 24 horas."}
      </p>
    </div>
  </div>
</section>

<style>
  .cta-contact {
    position: relative;
    padding-block: var(--space-20);
    background: linear-gradient(160deg, var(--color-slate-900), var(--color-slate-950));
    color: white;
    overflow: hidden;
  }

  /* ── Background ── */
  .cta-contact__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-contact__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.12;
  }

  .cta-contact__orb--green {
    width: 30rem;
    height: 30rem;
    background: var(--color-brand-600);
    top: -8rem;
    left: -6rem;
  }

  .cta-contact__orb--orange {
    width: 24rem;
    height: 24rem;
    background: var(--color-thermal-500);
    bottom: -6rem;
    right: -4rem;
  }

  .cta-contact__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgb(255 255 255 / 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / 0.025) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  /* ── Inner layout ── */
  .cta-contact__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    align-items: center;
    text-align: center;
  }

  @media (min-width: 768px) {
    .cta-contact__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
      gap: var(--space-16);
    }
  }

  /* ── Copy ── */
  .cta-contact__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 36rem;
  }

  .cta-contact__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-brand-400);
    width: fit-content;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .cta-contact__badge {
      margin-inline: 0;
    }
  }

  .cta-contact__title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.1;
  }

  .cta-contact__desc {
    font-size: 1rem;
    color: var(--color-slate-300);
    line-height: 1.7;
  }

  /* ── Action ── */
  .cta-contact__action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .cta-contact__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-8);
    background: var(--color-brand-600);
    color: white;
    font-size: 1rem;
    font-weight: 700;
    border-radius: var(--radius-md);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgb(22 163 74 / 0.3);
    white-space: nowrap;
  }

  .cta-contact__btn:hover {
    background: var(--color-brand-700);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgb(22 163 74 / 0.4);
  }

  .cta-contact__note {
    font-size: 0.75rem;
    color: var(--color-slate-500);
  }
</style>