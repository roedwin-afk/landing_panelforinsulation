---
import { ArrowRight, Layers, HelpCircle } from "lucide-astro";
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;

const base = import.meta.env.BASE_URL;
const prefix = lang === "es" ? `${base}es/` : base;
---

<section class="hero">
  <div class="hero__bg">
    <div class="hero__bg-orb hero__bg-orb--orange"></div>
    <div class="hero__bg-orb hero__bg-orb--green"></div>
    <div class="hero__bg-grid"></div>
  </div>

  <div class="container hero__container">

    <!-- Left column -->
    <div class="hero__left">
      <div class="hero__badge reveal" data-delay="0">
        <span class="hero__badge-dot"></span>
        {t.hero.badge}
      </div>

      <h1 class="hero__title reveal" data-delay="80">
        {t.hero.title1}
        <span class="hero__title-gradient">{t.hero.title2}</span>
      </h1>

      <p class="hero__description reveal" data-delay="160">
        {t.hero.description}
      </p>

      <div class="hero__actions reveal" data-delay="240">
        <a href={`${prefix}#calculator`} class="hero__btn-primary">
          {t.hero.ctaPrimary}
          <ArrowRight size={18} />
        </a>
        <a href={`${prefix}#what-is`} class="hero__btn-secondary">
          {t.hero.ctaSecondary}
        </a>
      </div>

      <!-- Stats -->
      <div class="hero__stats reveal" data-delay="320">
        <div class="hero__stat">
          <p class="hero__stat-value">{t.hero.stat1Value}</p>
          <p class="hero__stat-label">{t.hero.stat1Label}</p>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <p class="hero__stat-value">{t.hero.stat2Value}</p>
          <p class="hero__stat-label">{t.hero.stat2Label}</p>
        </div>
        <div class="hero__stat-divider"></div>
        <div class="hero__stat">
          <p class="hero__stat-value">{t.hero.stat3Value}</p>
          <p class="hero__stat-label">{t.hero.stat3Label}</p>
        </div>
      </div>
    </div>

    <!-- Right column: Buyer tip card -->
    <div class="hero__right reveal" data-delay="200">
      <div class="hero__card">
        <div class="hero__card-header">
          <div class="hero__card-icon">
            <HelpCircle size={20} />
          </div>
          <span class="hero__card-tag">Buyer Tip</span>
        </div>
        <h3 class="hero__card-title">{t.hero.cardTitle}</h3>
        <p class="hero__card-desc">{t.hero.cardDesc}</p>
        <div class="hero__card-items">
          <div class="hero__card-item">
            <span class="hero__card-item-name">{t.hero.cardPir}</span>
            <span class="hero__card-item-label hero__card-item-label--green">
              {t.hero.cardPirLabel}
            </span>
          </div>
          <div class="hero__card-item">
            <span class="hero__card-item-name">{t.hero.cardWool}</span>
            <span class="hero__card-item-label hero__card-item-label--orange">
              {t.hero.cardWoolLabel}
            </span>
          </div>
        </div>
        <a href={`${prefix}#what-is`} class="hero__card-cta">
          {t.hero.cardCta}
          <ArrowRight size={14} />
        </a>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    position: relative;
    background: linear-gradient(160deg, var(--color-slate-900) 0%, var(--color-slate-950) 100%);
    color: white;
    overflow: hidden;
    padding-block: 6rem 5rem;
  }

  /* ── Background ── */
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__bg-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    opacity: 0.1;
  }

  .hero__bg-orb--orange {
    width: 36rem;
    height: 36rem;
    background: var(--color-thermal-500);
    top: -8rem;
    right: -6rem;
  }

  .hero__bg-orb--green {
    width: 28rem;
    height: 28rem;
    background: var(--color-brand-600);
    bottom: -6rem;
    left: -6rem;
  }

  .hero__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgb(255 255 255 / 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgb(255 255 255 / 0.025) 1px, transparent 1px);
    background-size: 48px 48px;
  }

  /* ── Layout ── */
  .hero__container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero__container {
      grid-template-columns: 1fr 420px;
      gap: var(--space-16);
    }
  }

  /* ── Left column ── */
  .hero__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* ── Badge ── */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: rgb(255 255 255 / 0.07);
    border: 1px solid rgb(255 255 255 / 0.12);
    border-radius: var(--radius-full);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-brand-100);
    width: fit-content;
  }

  .hero__badge-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--color-brand-500);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ── Title ── */
  .hero__title {
    font-size: clamp(2.6rem, 5.5vw, 4.2rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    display: flex;
    flex-direction: column;
    gap: 0.15em;
  }

  .hero__title-gradient {
    background: linear-gradient(90deg, var(--color-brand-400) 0%, var(--color-thermal-400) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Description ── */
  .hero__description {
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-slate-300);
    max-width: 38rem;
  }

  /* ── Actions ── */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 0.85rem var(--space-6);
    background: var(--color-thermal-500);
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--radius-md);
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 24px rgb(249 115 22 / 0.28);
  }

  .hero__btn-primary:hover {
    background: var(--color-thermal-600);
    transform: translateY(-1px);
  }

  .hero__btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.85rem var(--space-6);
    background: rgb(255 255 255 / 0.07);
    border: 1px solid rgb(255 255 255 / 0.12);
    color: var(--color-slate-200);
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: var(--radius-md);
    transition: background 0.2s;
  }

  .hero__btn-secondary:hover {
    background: rgb(255 255 255 / 0.12);
  }

  /* ── Stats ── */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid rgb(255 255 255 / 0.08);
    flex-wrap: wrap;
  }

  .hero__stat-value {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-brand-400);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .hero__stat-label {
    font-size: 0.68rem;
    color: var(--color-slate-400);
    margin-top: 4px;
    line-height: 1.4;
    max-width: 7rem;
  }

  .hero__stat-divider {
    width: 1px;
    height: 2.2rem;
    background: rgb(255 255 255 / 0.1);
    flex-shrink: 0;
  }

  /* ── Right column ── */
  .hero__right {
    display: flex;
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero__right {
      justify-content: flex-end;
    }
  }

  /* ── Card ── */
  .hero__card {
    width: 100%;
    max-width: 26rem;
    background: rgb(255 255 255 / 0.05);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    backdrop-filter: blur(12px);
    box-shadow: 0 24px 48px rgb(0 0 0 / 0.3);
  }

  .hero__card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .hero__card-icon {
    width: 2.2rem;
    height: 2.2rem;
    background: rgb(22 163 74 / 0.15);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-400);
  }

  .hero__card-tag {
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--color-thermal-500);
    color: white;
    padding: 3px var(--space-2);
    border-radius: var(--radius-full);
  }

  .hero__card-title {
    font-size: 1rem;
    font-weight: 700;
    color: white;
    line-height: 1.4;
  }

  .hero__card-desc {
    font-size: 0.8rem;
    color: var(--color-slate-300);
    line-height: 1.65;
  }

  .hero__card-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .hero__card-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-2) var(--space-3);
    background: rgb(255 255 255 / 0.04);
    border: 1px solid rgb(255 255 255 / 0.06);
    border-radius: var(--radius-sm);
    gap: var(--space-3);
  }

  .hero__card-item-name {
    font-size: 0.74rem;
    color: var(--color-slate-300);
    font-weight: 500;
  }

  .hero__card-item-label {
    font-size: 0.68rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .hero__card-item-label--green { color: var(--color-brand-400); }
  .hero__card-item-label--orange { color: var(--color-thermal-400); }

  .hero__card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(255 255 255 / 0.55);
    padding: var(--space-2) var(--space-3);
    background: rgb(255 255 255 / 0.05);
    border: 1px solid rgb(255 255 255 / 0.08);
    border-radius: var(--radius-sm);
    transition: all 0.2s;
    margin-top: var(--space-1);
  }

  .hero__card-cta:hover {
    background: rgb(255 255 255 / 0.1);
    color: white;
  }
</style>