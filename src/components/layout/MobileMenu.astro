---
import NavLinks from "../ui/NavLinks.astro";
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;

const base = import.meta.env.BASE_URL;
const prefix = lang === "es" ? `${base}es/` : base;
---

<div id="mobile-menu" class="mobile-menu" aria-hidden="true">
  <div class="mobile-menu__backdrop"></div>
  <nav class="mobile-menu__panel">
    <NavLinks t={t} lang={lang} variant="mobile" />
    <div class="mobile-menu__footer">
      <a href={`${prefix}#download-guide`} class="mobile-menu__cta">
        {t.nav.cta}
      </a>
    </div>
  </nav>
</div>

<style>
  .mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 40;
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu__backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 0.4);
    backdrop-filter: blur(4px);
    animation: fadeIn 0.2s ease;
  }

  .mobile-menu__panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(20rem, 85vw);
    background: white;
    padding: var(--space-20) var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: var(--shadow-xl);
    animation: slideIn 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mobile-menu__footer {
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-slate-100);
  }

  .mobile-menu__cta {
    display: block;
    text-align: center;
    padding: var(--space-3) var(--space-4);
    background: var(--color-brand-600);
    color: white;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: background 0.2s ease;
  }

  .mobile-menu__cta:hover {
    background: var(--color-brand-700);
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideIn {
    from { transform: translateX(100%); }
    to { transform: translateX(0); }
  }
</style>

<script>
  function initMobileMenu() {
    const menu = document.getElementById("mobile-menu");
    const backdrop = menu?.querySelector(".mobile-menu__backdrop");
    const toggleBtn = document.getElementById("mobile-menu-toggle");

    if (!menu || !toggleBtn) return;

    function openMenu() {
      menu!.classList.add("is-open");
      menu!.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      menu!.classList.remove("is-open");
      menu!.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
    }

    toggleBtn.addEventListener("click", () => {
      menu.classList.contains("is-open") ? closeMenu() : openMenu();
    });

    backdrop?.addEventListener("click", closeMenu);

    // Cerrar al hacer click en un link interno
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  // Inicializar en carga normal y después de view transitions
  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
</script>