---
import NavLinks from "../ui/NavLinks.astro";
import MobileMenu from "./MobileMenu.astro";
import type { TranslationKeys } from "../../i18n/en";
import type { Lang } from "../../i18n/utils";
import { Layers } from "lucide-astro";

interface Props {
  t: TranslationKeys;
  lang: Lang;
}

const { t, lang } = Astro.props;

const base = import.meta.env.BASE_URL;
const prefix = lang === "es" ? `${base}es/` : base;
const alternateLang = lang === "en" ? "es" : "en";
const alternatePath = lang === "en" ? `${base}es/` : base;
---

<header class="navbar">
  <div class="container navbar__inner">

    <!-- Logo -->
    <a href={prefix} class="navbar__logo">
      <div class="navbar__logo-icon">
        <Layers size={22} />
      </div>
      <div>
        <span class="navbar__logo-text">
          panel<span class="navbar__logo-accent">for</span>insulation<span class="navbar__logo-dot">.com</span>
        </span>
        <p class="navbar__logo-sub">The Buyer's Knowledge Hub</p>
      </div>
    </a>

    <!-- Desktop Nav -->
    <nav class="navbar__nav" aria-label="Main navigation">
      <NavLinks t={t} lang={lang} variant="navbar" />
    </nav>

    <!-- Right actions -->
    <div class="navbar__actions">
      <!-- Language switcher -->
      <a href={alternatePath} class="navbar__lang-switch" aria-label="Switch language">
        {alternateLang.toUpperCase()}
      </a>

      <!-- CTA -->
      <a href={`${prefix}#download-guide`} class="navbar__cta">
        {t.nav.cta}
      </a>

      <!-- Mobile toggle -->
      <button
        id="mobile-menu-toggle"
        class="navbar__toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="navbar__toggle-bar"></span>
        <span class="navbar__toggle-bar"></span>
        <span class="navbar__toggle-bar"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu montado fuera del header -->
<MobileMenu t={t} lang={lang} />

<style>
